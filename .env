# =============================================================================
# DAVE DevBox — Environment Configuration
# =============================================================================
# Edit your keys here (GitHub web UI: your repo → .env → pencil icon)
# OR open the dashboard → Setup page after the Codespace starts.
#
# Repo MUST be PRIVATE if you add real keys.
# Free Gemini key: https://aistudio.google.com/apikey (no credit card)
# =============================================================================

# ── REQUIRED: Free Gemini AI key ─────────────────────────────────────────────
GEMINI_API_KEY=

# ── a-Shell SSH public key ────────────────────────────────────────────────────
# In a-Shell mini: ssh-keygen -t ed25519  →  cat ~/.ssh/id_ed25519.pub
# Paste the full line starting with ssh-ed25519 below (no quotes):
ASHELL_SSH_PUBKEY=

# ── GitHub (for git push from web app) ────────────────────────────────────────
# github.com/settings/tokens → Classic → repo scope
GITHUB_TOKEN=
GITHUB_REMOTE=https://github.com/daviddan-241/D-A-N22
GITHUB_BRANCH=main

# ── Optional extra AI providers ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Aider settings ────────────────────────────────────────────────────────────
AIDER_MODEL=gemini/gemini-2.0-flash
AIDER_USE_TOR=false

# ── Dashboard login ───────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=dave2024

# ── Ollama (optional local AI) ────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
