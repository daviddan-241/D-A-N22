# =============================================================================
# DAVE DevBox — Environment
# Get your FREE Gemini key at: https://aistudio.google.com/apikey
# This file is in the repo so Codespaces auto-loads it.
# Your repo MUST be private if you add a real key here.
# =============================================================================

# ── REQUIRED: Your free Google Gemini API key ─────────────────────────────────
GEMINI_API_KEY=

# ── Optional: additional AI providers ────────────────────────────────────────
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Aider model (gemini-2.0-flash = fast + free) ─────────────────────────────
AIDER_MODEL=gemini/gemini-2.0-flash

# ── Dashboard login ───────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=dave2024
DASHBOARD_SECRET=dave-devbox-secret-change-me

# ── Ollama (optional local AI) ────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
