# =============================================================================
# DAVE DevBox — Environment Configuration
# =============================================================================
# HOW TO SET YOUR KEYS:
#   Option A (easiest): Open the dashboard at http://localhost:3000 → Setup page
#   Option B: Edit this file directly on GitHub (your repo → .env → edit)
#   Option C: Edit in the dashboard → Files → .env
#
# Your repo MUST be private if you put real keys here.
# Get a free Gemini key at: https://aistudio.google.com/apikey (no credit card)
# =============================================================================

# ── REQUIRED: Free Gemini AI key ─────────────────────────────────────────────
GEMINI_API_KEY=

# ── a-Shell SSH public key (paste here OR add via Setup page in the web app) ──
# In a-Shell mini: ssh-keygen -t ed25519  then  cat ~/.ssh/id_ed25519.pub
# Paste the whole line starting with ssh-ed25519 below:
ASHELL_SSH_PUBKEY=

# ── GitHub (for git push from the web app) ────────────────────────────────────
# Create at: https://github.com/settings/tokens (Classic, repo scope)
GITHUB_TOKEN=
GITHUB_REMOTE=https://github.com/daviddan-241/D-A-N22
GITHUB_BRANCH=main

# ── Optional: additional AI providers ────────────────────────────────────────
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Aider model ───────────────────────────────────────────────────────────────
AIDER_MODEL=gemini/gemini-2.0-flash
AIDER_USE_TOR=false

# ── Dashboard login ───────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=dave2024

# ── Ollama (optional local AI) ────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
