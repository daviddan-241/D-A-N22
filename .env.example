# =============================================================================
# DAVE DevBox — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Add at least one. DAVE auto-detects which are available.

# OpenAI (GPT-4, GPT-3.5, etc.)
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# OpenRouter (access 100+ models with one key)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/anthropic/claude-3.5-sonnet

# Custom OpenAI-compatible API base URL
OPENAI_API_BASE=

# ─── Local AI (Ollama) ────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Model Overrides ──────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini/gemini-1.5-pro

# ─── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_SECRET=change-me-to-a-random-string
DASHBOARD_USERNAME=admin
# Password is hashed by dashboard at first run — set plain text here once only
DASHBOARD_PASSWORD=

# ─── SSH ──────────────────────────────────────────────────────────────────────
SSH_PORT=22

# ─── GitHub (optional — for git operations in dashboard) ──────────────────────
GITHUB_TOKEN=
GITHUB_USERNAME=
